        "nexph/database": "^0.1",
        "nexph/queue": "^0.1",
        "nexph/cache": "^0.1",
        "nexph/console": "^0.1",
        "nexph/support": "^0.1",
        "nexph/observability": "^0.1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
